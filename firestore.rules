rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper Functions
    function isAuthenticated() {
      return true; // No-login mode enabled
    }
    
    function isAdmin() {
      return true; // Access controlled by password in UI
    }

    function isOwner(userId) {
      return true; // Relational checks removed to support no-login flow
    }

    function isDocOwner() {
      return true;
    }

    function isNewDocOwner() {
      return true;
    }

    // Validation Helpers
    function isValidFgrMission(data) {
      return data.uid is string &&
             data.missao is string && data.missao.size() < 200 &&
             data.createdAt is string;
    }

    function isValidRelprevReport(data) {
      return data.uid is string &&
             data.codigo is string &&
             data.relato is string && data.relato.size() < 5000 &&
             data.createdAt is string;
    }

    // FGR Missions
    match /fgrMissions/{missionId} {
      allow read, create, update, delete: if isAuthenticated();
    }

    // RELPREV Reports
    match /relprevReports/{reportId} {
      allow read, create, update, delete: if isAuthenticated();
    }

    // Lancamentos (PDV Extractor Data)
    match /Lancamentos/{id} {
      allow read, write: if true;
    }

    // Config
    match /config/abastecimento {
      allow read, write: if true;
    }

    function isValidAbastecimentoFile(data) {
      return data.name is string && data.name.size() < 255 &&
             data.url is string && data.url.size() < 1000 &&
             data.createdAt is string;
    }

    // Abastecimento Files
    match /documentos_abastecimento/{fileId} {
      allow read: if true;
      allow create, update: if isValidAbastecimentoFile(request.resource.data);
      allow delete: if true;
    }

    // Default Deny
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
