rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper Functions
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isDocOwner() {
      return isAuthenticated() && request.auth.uid == resource.data.uid;
    }

    function isNewDocOwner() {
      return isAuthenticated() && request.auth.uid == request.resource.data.uid;
    }

    // Check if user is the admin (Simplified to any authenticated user as requested)
    function isAdmin() {
      return isAuthenticated() && 
        request.auth.token.email_verified == true;
    }

    // Validation Helpers
    function isValidFgrMission(data) {
      return data.uid is string &&
             data.missao is string && data.missao.size() < 200 &&
             data.createdAt is string;
    }

    function isValidRelprevReport(data) {
      return data.uid is string &&
             data.codigo is string &&
             data.relato is string && data.relato.size() < 5000 &&
             data.createdAt is string;
    }

    // FGR Missions
    match /fgrMissions/{missionId} {
      allow read, create, update, delete: if true;
    }

    // RELPREV Reports
    match /relprevReports/{reportId} {
      allow read, create, update, delete: if true;
    }

    // Config
    match /config/abastecimento {
      allow read: if true;
      allow write: if isAdmin();
    }

    function isValidAbastecimentoFile(data) {
      return data.name is string && data.name.size() < 255 &&
             data.url is string && data.url.size() < 1000 &&
             data.createdAt is string;
    }

    // Abastecimento Files
    match /abastecimento_files/{fileId} {
      allow read: if true;
      allow write: if isAdmin() && isValidAbastecimentoFile(request.resource.data);
    }

    // Default Deny
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
