{
  "entities": {
    "FgrMission": {
      "title": "FgrMission",
      "description": "Uma missão cadastrada no formulário FGR (Ficha de Gerenciamento de Risco)",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "ID do usuário autor" },
        "missao": { "type": "string", "description": "Nome da missão/OMO" },
        "local": { "type": "string", "description": "Local da missão" },
        "data": { "type": "string", "format": "date", "description": "Data da missão" },
        "preenchidoPor": { "type": "string", "description": "Nome do responsável" },
        "funcao": { "type": "string", "description": "Função (PI/PO/PB)" },
        "tipoVoo": { "type": "string", "description": "Código do perfil de voo" },
        "p3Selections": { "type": "object", "description": "Votos da Parte III" },
        "p4Selections": { "type": "object", "description": "Votos da Parte IV" },
        "gravidadeSelections": { "type": "object", "description": "Fatores de gravidade selecionados" },
        "scores": {
          "type": "object",
          "properties": {
            "tgMin": { "type": "number" },
            "tgMax": { "type": "number" },
            "gravTotal": { "type": "number" },
            "riskMin": { "type": "number" },
            "riskMax": { "type": "number" }
          }
        },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "missao", "data", "createdAt"]
    },
    "RelprevReport": {
      "title": "RelprevReport",
      "description": "Um relato de prevenção de acidente aeronáutico",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "ID do usuário autor" },
        "codigo": { "type": "string", "description": "Código do relatório (ex: 2026-001)" },
        "dataOcorrencia": { "type": "string", "format": "date" },
        "identificacao": { "type": "string", "description": "Identidade do relator (opcional)" },
        "local": { "type": "string" },
        "assunto": { "type": "string" },
        "relato": { "type": "string" },
        "analise": { "type": "string" },
        "medidas": { "type": "string" },
        "status": { "type": "string", "enum": ["ENVIADO", "EM ANÁLISE", "FINALIZADO"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "codigo", "relato", "createdAt"]
    }
  },
  "firestore": {
    "/fgrMissions/{missionId}": {
      "schema": "FgrMission",
      "description": "Histórico de missões FGR"
    },
    "/relprevReports/{reportId}": {
      "schema": "RelprevReport",
      "description": "Relatos de prevenção"
    },
    "/config/abastecimento": {
      "schema": {
        "title": "AppConfig",
        "description": "Configurações globais do aplicativo",
        "type": "object",
        "properties": {
          "url": { "type": "string", "description": "URL do arquivo de abastecimento" },
          "updatedAt": { "type": "string", "description": "Data da última atualização" },
          "updatedBy": { "type": "string", "description": "Email do admin que atualizou" }
        }
      },
      "description": "Documentos de configuração"
    },
    "/abastecimento_files/{fileId}": {
      "schema": {
        "title": "AbastecimentoFile",
        "description": "A PDF file for fueling guidance",
        "type": "object",
        "properties": {
          "name": { "type": "string" },
          "url": { "type": "string" },
          "size": { "type": "number" },
          "createdAt": { "type": "string" },
          "createdBy": { "type": "string" }
        }
      },
      "description": "Collection of all uploaded PDFs for fueling"
    }
  }
}
